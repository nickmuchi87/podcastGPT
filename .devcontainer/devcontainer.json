{
  "name": "PodcastGPT Development",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "podcast_frontend.py"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "updateContentCommand": "pip3 install --user -r requirements.txt && echo '✅ Dependencies installed'",
  "postAttachCommand": {
    "server": "streamlit run podcast_frontend.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "PodcastGPT",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [8501]
}
